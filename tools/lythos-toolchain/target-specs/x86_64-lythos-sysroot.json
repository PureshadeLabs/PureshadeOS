{
  "_comment": "Sysroot/toolchain target for x86_64-lythos. Used ONLY by tools/lythos-toolchain scripts to build the Rust sysroot.",
  "_comment2": "NOT the same as targets/x86_64-lythos.json (the kernel target). Key divergences: os='lythos' (not 'none'), broader SSE disable, pre-link-args -nostdlib/-static, relro/rpath/thread-local flags needed by sysroot. Keep these in sync intentionally."

  "llvm-target":         "x86_64-unknown-none-elf",
  "data-layout":         "e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-f80:128-n8:16:32:64-S128",
  "arch":                "x86_64",
  "target-endian":       "little",
  "target-pointer-width": 64,
  "target-c-int-width":  32,

  "os":                  "lythos",
  "vendor":              "unknown",
  "env":                 "",
  "abi":                 "",

  "linker-flavor":       "gnu-lld",
  "linker":              "rust-lld",
  "lld-flavor":          "ld",

  "panic-strategy":      "abort",
  "disable-redzone":     true,

  "features":            "-mmx,-sse,-sse2,-sse3,-ssse3,-sse4.1,-sse4.2,-avx,-avx2,+soft-float",
  "rustc-abi":           "softfloat",

  "executables":         true,
  "static-position-independent-executables": false,
  "position-independent-executables": false,

  "relro-level":         "off",

  "has-rpath":           false,
  "has-thread-local":    false,

  "stack-probes":        { "kind": "none" },

  "pre-link-args": {
    "gnu-lld": ["-nostdlib", "-static"]
  },

  "post-link-args": {},

  "emit-debug-gdb-scripts": false,

  "supported-sanitizers": []
}
